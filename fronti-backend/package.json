{
  "name": "fronti-backend",
  "version": "0.1.0",
  "description": "MVP backend for Fronti AI, a Venezuelan business agent for WhatsApp.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:3001": "cross-env PORT=3001 nest start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "jest",
    "test:skills": "jest --runInBand --testPathPatterns=src/fronti/skills",
    "check:encoding": "node ../scripts/check-encoding.js",
    "check:database-encoding": "node scripts/check-database-encoding.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cross-env": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
